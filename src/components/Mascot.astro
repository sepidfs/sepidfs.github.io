---
const photo = "/images/mascot.png";
---

<div id="mascot" class="fixed bottom-5 right-5 z-[60] select-none">
  <div
    id="mascot-bubble"
    class="pointer-events-none absolute bottom-full right-0 mb-3 w-64 translate-y-2 rounded-2xl border border-white/15 bg-[#0b0e18]/95 px-4 py-3 text-sm italic text-gray-200 opacity-0 shadow-2xl backdrop-blur-md transition-all duration-300"
  >
    <span id="mascot-text"></span>
    <span class="absolute -bottom-1.5 right-8 h-3 w-3 rotate-45 border-b border-r border-white/15 bg-[#0b0e18]/95"></span>
  </div>

  <button
    id="mascot-btn"
    aria-label="Talk to me"
    class="group relative block h-32 w-32 overflow-hidden rounded-full border-2 border-white/25 bg-[#0b0e18] shadow-2xl transition hover:scale-105 hover:border-pink-300/60 focus:outline-none"
  >
    <img
      id="mascot-img"
      src={photo}
      alt="Sepideh"
      class="h-full w-full rounded-full object-cover object-[center_38%] scale-[1.9] brightness-150 contrast-150"
      draggable="false"
    />

    <!-- فقط مردمک‌ها حرکت می‌کنند -->
    <span
      class="mascot-eye pointer-events-none absolute left-[43.8%] top-[38.6%] h-[7px] w-[7px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#4b2a10] shadow-[0_0_4px_rgba(255,255,255,0.65)]"
    ></span>

    <span
      class="mascot-eye pointer-events-none absolute left-[56.4%] top-[39.1%] h-[7px] w-[7px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#4b2a10] shadow-[0_0_4px_rgba(255,255,255,0.65)]"
    ></span>

    <!-- پلک‌ها -->
    <span
      class="mascot-lid pointer-events-none absolute left-[37.8%] top-[35.2%] h-[12px] w-[20px] rounded-full bg-[#050505] opacity-0"
    ></span>

    <span
      class="mascot-lid pointer-events-none absolute left-[50.5%] top-[35.7%] h-[12px] w-[20px] rounded-full bg-[#050505] opacity-0"
    ></span>

    <span class="absolute bottom-1.5 right-1.5 h-3 w-3 rounded-full border-2 border-[#0b0e18] bg-green-400"></span>
  </button>
</div>

<style>
  .mascot-blink .mascot-lid {
    animation: mascotBlink 170ms ease-in-out;
  }

  @keyframes mascotBlink {
    0% {
      opacity: 0;
      transform: scaleY(0);
      transform-origin: top;
    }

    45% {
      opacity: 1;
      transform: scaleY(1.25);
      transform-origin: top;
    }

    100% {
      opacity: 0;
      transform: scaleY(0);
      transform-origin: top;
    }
  }
</style>

<script is:inline>
  (() => {
    const lines = [
      "Hi! Welcome to my little corner of the internet.",
      "Feel free to explore my research, publications, and projects.",
      "Warning: Mathematical curiosity may be contagious.",
      "Machine learning is fun. Proving why it works is even better.",
      "Some ideas begin with coffee. The good ones end with proofs.",
      "Optimization is where mathematics meets intelligence.",
      "Behind every model is a mathematical story.",
      "Thanks for visiting — I hope you enjoy exploring my work!",
    ];

    const btn = document.getElementById("mascot-btn");
    const bubble = document.getElementById("mascot-bubble");
    const text = document.getElementById("mascot-text");
    const eyes = document.querySelectorAll(".mascot-eye");

    window.addEventListener("mousemove", (event) => {
      eyes.forEach((eye) => {
        const rect = eye.getBoundingClientRect();

        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;

        const dx = event.clientX - cx;
        const dy = event.clientY - cy;

        const angle = Math.atan2(dy, dx);
        const distance = 2.6;

        const x = Math.cos(angle) * distance;
        const y = Math.sin(angle) * distance;

        eye.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`;
      });
    });

    function blink() {
      btn?.classList.add("mascot-blink");

      setTimeout(() => {
        btn?.classList.remove("mascot-blink");
      }, 190);

      setTimeout(blink, 2800 + Math.random() * 3500);
    }

    setTimeout(blink, 1800);

    function showBubble(message) {
      text.textContent = message;

      bubble.classList.remove("opacity-0", "translate-y-2");
      bubble.classList.add("opacity-100", "translate-y-0");

      setTimeout(() => {
        bubble.classList.add("opacity-0", "translate-y-2");
        bubble.classList.remove("opacity-100", "translate-y-0");
      }, 4300);
    }

    setTimeout(() => {
      showBubble(lines[0]);
    }, 1200);

    btn?.addEventListener("click", () => {
      const random = lines[Math.floor(Math.random() * lines.length)];
      showBubble(random);
    });
  })();
</script>