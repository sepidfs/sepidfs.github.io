<div id="mascot" class="fixed bottom-5 right-5 z-[60] select-none" style="perspective:800px;">
  <div
    id="mascot-bubble"
    class="pointer-events-none absolute bottom-full right-0 mb-3 w-64 translate-y-2 rounded-2xl border border-white/15 bg-[#0b0e18]/95 px-4 py-3 text-sm italic text-gray-200 opacity-0 shadow-2xl backdrop-blur-md transition-all duration-300"
  >
    <span id="mascot-text"></span>
    <span class="absolute -bottom-1.5 right-8 h-3 w-3 rotate-45 border-b border-r border-white/15 bg-[#0b0e18]/95"></span>
  </div>

  <button
    id="mascot-btn"
    aria-label="Talk to me"
    class="relative block h-32 w-32 overflow-hidden rounded-full border-2 border-white/25 bg-[#050507] shadow-2xl transition-colors duration-200 hover:border-pink-300/60 focus:outline-none"
  >
    <svg id="mascot-svg" viewBox="0 0 128 128" class="h-full w-full rounded-full">
      <circle cx="64" cy="64" r="61" fill="#030305" stroke="#4d4a62" stroke-width="3"/>

      <g id="mascot-head">
        <path d="M23 93 C24 63 33 34 58 20 C78 9 101 22 108 47 C113 66 106 90 97 110"
              fill="none" stroke="#f5f5f5" stroke-width="2.1" stroke-linecap="round"/>
        <path d="M31 98 C35 63 46 34 75 21" fill="none" stroke="#f5f5f5" stroke-width="1.8" stroke-linecap="round"/>
        <path d="M49 23 C35 42 30 68 34 101" fill="none" stroke="#f5f5f5" stroke-width="1.4" stroke-linecap="round"/>
        <path d="M75 21 C92 35 98 59 93 86 C90 100 80 111 66 112 C49 111 39 96 37 80"
              fill="none" stroke="#f5f5f5" stroke-width="1.8" stroke-linecap="round"/>
        <path d="M75 23 C68 39 58 49 44 58" fill="none" stroke="#f5f5f5" stroke-width="1.5" stroke-linecap="round"/>

        <path d="M49 55 C54 50 61 50 66 55" fill="none" stroke="#f5f5f5" stroke-width="1.6" stroke-linecap="round"/>
        <path d="M79 57 C84 53 91 54 95 59" fill="none" stroke="#f5f5f5" stroke-width="1.6" stroke-linecap="round"/>

        <circle id="left-iris" cx="57" cy="55" r="3.2" fill="#9b5b18"/>
        <circle id="right-iris" cx="87" cy="58" r="3.2" fill="#9b5b18"/>
        <circle id="left-pupil" cx="57" cy="55" r="1.25" fill="#030303"/>
        <circle id="right-pupil" cx="87" cy="58" r="1.25" fill="#030303"/>

        <path d="M70 62 C68 68 65 72 62 76 C66 78 70 77 73 74"
              fill="none" stroke="#f5f5f5" stroke-width="1.4" stroke-linecap="round"/>

        <path d="M50 87 C59 96 75 97 86 88 C76 91 61 91 50 87 Z"
              fill="#d88983" stroke="#f5f5f5" stroke-width="1.1"/>
        <path d="M54 88 C65 91 75 91 83 88" fill="none" stroke="#111" stroke-width="1"/>

        <path d="M92 75 C96 81 96 89 92 95" fill="none" stroke="#f5f5f5" stroke-width="1.2"/>
        <circle cx="92" cy="98" r="2.3" fill="none" stroke="#f5f5f5" stroke-width="1.2"/>

        <path d="M35 103 C44 111 54 116 66 117" fill="none" stroke="#f5f5f5" stroke-width="1.3" stroke-linecap="round"/>
        <path d="M99 82 C103 96 104 107 103 117" fill="none" stroke="#f5f5f5" stroke-width="1.3" stroke-linecap="round"/>
      </g>
    </svg>

    <span class="absolute bottom-1.5 right-1.5 h-3 w-3 rounded-full border-2 border-[#0b0e18] bg-green-400"></span>
  </button>
</div>

<script is:inline>
  (() => {
    const lines = [
      "Hi! Welcome to my little corner of the internet.",
      "Feel free to explore my research, publications, and projects.",
      "Warning: Mathematical curiosity may be contagious.",
      "Machine learning is easy... until the math shows up.",
      "Some ideas begin with coffee. The good ones end with proofs.",
      "Optimization is where mathematics meets intelligence.",
      "Behind every model is a mathematical story.",
      "Thanks for visiting - I hope you enjoy exploring my work!",
    ];

    const btn = document.getElementById("mascot-btn");
    const head = document.getElementById("mascot-head");
    const bubble = document.getElementById("mascot-bubble");
    const text = document.getElementById("mascot-text");

    const eyes = [
      document.getElementById("left-iris"),
      document.getElementById("right-iris"),
      document.getElementById("left-pupil"),
      document.getElementById("right-pupil"),
    ];

    let tx = 0, ty = 0, cx = 0, cy = 0;

    window.addEventListener("mousemove", (e) => {
      const r = btn.getBoundingClientRect();
      const mx = r.left + r.width / 2;
      const my = r.top + r.height / 2;

      tx = Math.max(-1, Math.min(1, (e.clientX - mx) / 420));
      ty = Math.max(-1, Math.min(1, (e.clientY - my) / 420));
    });

    function animate() {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;

      head.style.transformOrigin = "64px 66px";
      head.style.transform =
        `rotate(${cx * 3}deg) translate(${cx * 2.5}px, ${cy * 2}px)`;

      eyes.forEach((eye) => {
        eye.style.transform = `translate(${cx * 2.2}px, ${cy * 1.3}px)`;
      });

      requestAnimationFrame(animate);
    }

    animate();

    let bubbleTimer = null;

    function showBubble(message, duration = 4000) {
      text.textContent = message;

      bubble.classList.remove("opacity-0", "translate-y-2");
      bubble.classList.add("opacity-100", "translate-y-0");

      if (bubbleTimer) clearTimeout(bubbleTimer);

      bubbleTimer = setTimeout(() => {
        bubble.classList.add("opacity-0", "translate-y-2");
        bubble.classList.remove("opacity-100", "translate-y-0");
      }, duration);
    }

    setTimeout(() => showBubble(lines[0], 4500), 1200);

    btn.addEventListener("click", () => {
      showBubble(lines[Math.floor(Math.random() * lines.length)], 4000);
    });
  })();
</script>