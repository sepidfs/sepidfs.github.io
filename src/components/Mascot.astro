---
const photo = "/images/mascot.png";
---

<div id="mascot" class="fixed bottom-5 right-5 z-[60] select-none" style="perspective: 800px;">
  <div id="mascot-bubble" class="pointer-events-none absolute bottom-full right-0 mb-3 w-64 translate-y-2 rounded-2xl border border-white/15 bg-[#0b0e18]/95 px-4 py-3 text-sm italic text-gray-200 opacity-0 shadow-2xl backdrop-blur-md transition-all duration-300">
    <span id="mascot-text"></span>
    <span class="absolute -bottom-1.5 right-8 h-3 w-3 rotate-45 border-b border-r border-white/15 bg-[#0b0e18]/95"></span>
  </div>

  <button id="mascot-btn" aria-label="Talk to me" class="relative block h-32 w-32 overflow-hidden rounded-full border-2 border-white/25 bg-[#0b0e18] shadow-2xl transition-colors duration-200 hover:border-pink-300/60 focus:outline-none">
    <div id="mascot-head" class="relative h-full w-full rounded-full">
      <img id="mascot-img" src={photo} alt="Sepideh" class="absolute inset-0 h-full w-full rounded-full object-cover" draggable="false" />

      <span class="eye-mask left-mask"></span>
      <span class="eye-mask right-mask"></span>

      <span class="eye left-eye"><span class="iris"><span class="pupil"></span></span></span>
      <span class="eye right-eye"><span class="iris"><span class="pupil"></span></span></span>

      <span id="mascot-lid"></span>
    </div>

    <span class="absolute bottom-1.5 right-1.5 h-3 w-3 rounded-full border-2 border-[#0b0e18] bg-green-400"></span>
  </button>
</div>

<style>
  #mascot-head {
    will-change: transform;
    transform-style: preserve-3d;
  }

  #mascot-img {
    pointer-events: none;
  }

  .eye-mask {
    position: absolute;
    z-index: 3;
    background: #020202;
    border-radius: 50%;
  }

  .left-mask {
    left: 46px;
    top: 48px;
    width: 22px;
    height: 13px;
    transform: rotate(10deg);
  }

  .right-mask {
    left: 77px;
    top: 52px;
    width: 21px;
    height: 13px;
    transform: rotate(-6deg);
  }

  .eye {
    position: absolute;
    z-index: 5;
    width: 11px;
    height: 5px;
    border-radius: 50%;
    background: #fff;
    overflow: hidden;
    border: 0.6px solid rgba(255,255,255,.9);
    box-shadow: 0 0 1px rgba(255,255,255,.4);
  }

  .left-eye {
    left: 52px;
    top: 51px;
    transform: rotate(8deg) scaleY(.78);
  }

  .right-eye {
    left: 82px;
    top: 54px;
    transform: rotate(-5deg) scaleY(.78);
  }

  .iris {
    position: absolute;
    left: 4px;
    top: 1px;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #9b5b18;
    transition: transform .05s linear;
  }

  .pupil {
    position: absolute;
    left: 1px;
    top: 1px;
    width: 1px;
    height: 1px;
    border-radius: 50%;
    background: #000;
  }

  #mascot-lid {
    position: absolute;
    z-index: 8;
    inset-inline: 0;
    top: 0;
    height: 0;
    background: rgba(0,0,0,0.96);
    pointer-events: none;
    transition: height 0.11s ease-in;
  }
</style>

<script is:inline>
  (() => {
    const lines = [
      "Hi! Welcome to my little corner of the internet.",
      "Feel free to explore my research, publications, and projects.",
      "Warning: Mathematical curiosity may be contagious.",
      "Machine learning is easy... until the math shows up.",
      "Some ideas begin with coffee. The good ones end with proofs.",
      "Optimization is where mathematics meets intelligence.",
      "Behind every model is a mathematical story.",
      "Thanks for visiting - I hope you enjoy exploring my work!",
    ];

    const btn = document.getElementById("mascot-btn");
    const head = document.getElementById("mascot-head");
    const lid = document.getElementById("mascot-lid");
    const bubble = document.getElementById("mascot-bubble");
    const text = document.getElementById("mascot-text");
    const irises = document.querySelectorAll(".iris");

    let tx = 0, ty = 0;
    let cx = 0, cy = 0;

    window.addEventListener("mousemove", (e) => {
      const r = btn.getBoundingClientRect();
      const mx = r.left + r.width / 2;
      const my = r.top + r.height / 2;

      tx = Math.max(-1, Math.min(1, (e.clientX - mx) / 420));
      ty = Math.max(-1, Math.min(1, (e.clientY - my) / 420));
    });

    function animateFace() {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;

      head.style.transform =
        `rotateY(${cx * 12}deg) rotateX(${-cy * 9}deg) translate(${cx * 3}px, ${cy * 2}px)`;

      irises.forEach((eye) => {
        eye.style.transform = `translate(${cx * 2}px, ${cy * 1px}px)`;
      });

      requestAnimationFrame(animateFace);
    }

    animateFace();

    function blink() {
      lid.style.height = "58%";
      setTimeout(() => { lid.style.height = "0"; }, 120);
      setTimeout(blink, 3000 + Math.random() * 4500);
    }

    setTimeout(blink, 2200);

    let bubbleTimer = null;

    function showBubble(message, duration = 4000) {
      text.textContent = message;
      bubble.classList.remove("opacity-0", "translate-y-2");
      bubble.classList.add("opacity-100", "translate-y-0");

      if (bubbleTimer) clearTimeout(bubbleTimer);

      bubbleTimer = setTimeout(() => {
        bubble.classList.add("opacity-0", "translate-y-2");
        bubble.classList.remove("opacity-100", "translate-y-0");
      }, duration);
    }

    setTimeout(() => showBubble(lines[0], 4500), 1200);

    btn.addEventListener("click", () => {
      showBubble(lines[Math.floor(Math.random() * lines.length)], 4000);
    });
  })();
</script>