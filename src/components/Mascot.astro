---
// Interactive corner mascot - uses your real line-art portrait, with small
// dark pupils overlaid on the the drawing eyes that follow the mouse, plus a
// click-to-talk speech bubble (welcoming + research/PhD lines).
//
// SETUP: save your portrait at  public/images/mascot.png
// Then fine-tune the two .mascot-pupil left/top % values so the moving pupils
// sit exactly over the eyes of YOUR image.
const photo = "/images/mascot.png";
---
<div id="mascot" class="fixed bottom-5 right-5 z-[60] select-none">
  <!-- speech bubble -->
  <div
    id="mascot-bubble"
    class="pointer-events-none absolute bottom-full right-0 mb-3 w-60 translate-y-2 rounded-2xl border border-white/15 bg-[#0b0e18]/95 px-4 py-3 text-sm italic text-gray-200 opacity-0 shadow-2xl backdrop-blur-md transition-all duration-300"
  >
    <span id="mascot-text"></span>
    <span class="absolute -bottom-1.5 right-8 h-3 w-3 rotate-45 border-b border-r border-white/15 bg-[#0b0e18]/95"></span>
  </div>

  <!-- avatar button -->
  <button
    id="mascot-btn"
    aria-label="Talk to me"
    class="group relative block h-32 w-32 overflow-hidden rounded-full border-2 border-white/25 bg-[#0b0e18] shadow-2xl transition hover:scale-105 hover:border-pink-300/60 focus:outline-none"
  >
    <img
      src={photo}
      alt="Sepideh"
      class="h-full w-full rounded-full object-cover object-[center_32%] scale-[1.55] brightness-125 contrast-150 saturate-125"
      draggable="false"
    />

    <span class="mascot-pupil pointer-events-none absolute left-[44%] top-[39%] h-[5px] w-[5px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#3a2a1e] transition-transform duration-75"></span>
    <span class="mascot-pupil pointer-events-none absolute left-[57%] top-[40%] h-[5px] w-[5px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#3a2a1e] transition-transform duration-75"></span>

    <span class="absolute bottom-1.5 right-1.5 h-3 w-3 rounded-full border-2 border-[#0b0e18] bg-green-400"></span>
  </button>
</div>

<script is:inline>
  (() => {
    const lines = [
      "Hi! Welcome to my little corner of the internet.",
      "Feel free to explore my research, publications, and projects.",
      "Warning: Mathematical curiosity may be contagious.",
      "Machine learning is easy... until the math shows up.",
      "Some ideas begin with coffee. The good ones end with proofs.",
      "Optimization is where mathematics meets intelligence.",
      "Behind every model is a mathematical story.",
      "Thanks for visiting - I hope you enjoy exploring my work!",
    ];

    const btn = document.getElementById("mascot-btn");
    const bubble = document.getElementById("mascot-bubble");
    const text = document.getElementById("mascot-text");
    const pupils = document.querySelectorAll(".mascot-pupil");

    // pupils follow the mouse (small travel so they stay over the eyes)
    window.addEventListener("mousemove", (e) => {
      pupils.forEach((p) => {
        const r = p.getBoundingClientRect();
        const cx = r.left + r.width / 2;
        const cy = r.top + r.height / 2;
        const angle = Math.atan2(e.clientY - cy, e.clientX - cx);
        const dist = 1.8;
        const x = Math.cos(angle) * dist;
        const y = Math.sin(angle) * dist;
        p.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`;
      });
    });

    // greet once on first load
    setTimeout(() => {
      text.textContent = "Hi! Welcome to my little corner of the internet.";
      bubble.classList.remove("opacity-0", "translate-y-2");
      bubble.classList.add("opacity-100", "translate-y-0");
      setTimeout(() => {
        bubble.classList.add("opacity-0", "translate-y-2");
        bubble.classList.remove("opacity-100", "translate-y-0");
      }, 4500);
    }, 1200);

    // click to talk
    let hideTimer = null;
    btn.addEventListener("click", () => {
      text.textContent = lines[Math.floor(Math.random() * lines.length)];
      bubble.classList.remove("opacity-0", "translate-y-2");
      bubble.classList.add("opacity-100", "translate-y-0");
      if (hideTimer) clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        bubble.classList.add("opacity-0", "translate-y-2");
        bubble.classList.remove("opacity-100", "translate-y-0");
      }, 4000);
    });
  })();
</script>
