---
const photo = "/images/mascot.png";
---

<div id="mascot" class="fixed bottom-5 right-5 z-[60] select-none" style="perspective: 800px;">
  <div
    id="mascot-bubble"
    class="pointer-events-none absolute bottom-full right-0 mb-3 w-64 translate-y-2 rounded-2xl border border-white/15 bg-[#0b0e18]/95 px-4 py-3 text-sm italic text-gray-200 opacity-0 shadow-2xl backdrop-blur-md transition-all duration-300"
  >
    <span id="mascot-text"></span>
    <span class="absolute -bottom-1.5 right-8 h-3 w-3 rotate-45 border-b border-r border-white/15 bg-[#0b0e18]/95"></span>
  </div>

  <button
    id="mascot-btn"
    aria-label="Talk to me"
    class="group relative block h-32 w-32 overflow-hidden rounded-full border-2 border-white/25 bg-[#0b0e18] shadow-2xl transition-colors duration-200 hover:border-pink-300/60 focus:outline-none"
    style="transform-style: preserve-3d;"
  >
    <div id="mascot-head" class="relative h-full w-full rounded-full" style="transform-style: preserve-3d;">
      <img
        id="mascot-img"
        src={photo}
        alt="Sepideh"
        class="h-full w-full rounded-full object-cover object-[center_30%] scale-[1.5] brightness-150 contrast-150"
        draggable="false"
      />

      <span class="mascot-eye left-eye">
        <span class="mascot-pupil"></span>
      </span>

      <span class="mascot-eye right-eye">
        <span class="mascot-pupil"></span>
      </span>

      <span id="mascot-lid"></span>
    </div>

    <span class="absolute bottom-1.5 right-1.5 h-3 w-3 rounded-full border-2 border-[#0b0e18] bg-green-400"></span>
  </button>
</div>

<style>
  #mascot-head {
    transition: transform 0.08s linear;
    will-change: transform;
  }

  #mascot-img {
    pointer-events: none;
    transition: transform 0.08s linear;
  }

  .mascot-eye {
    position: absolute;
    z-index: 5;
    width: 14px;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    overflow: hidden;
    box-shadow: 0 0 3px rgba(255,255,255,0.45);
  }

  .left-eye {
    left: 50px;
    top: 52px;
    transform: rotate(8deg);
  }

  .right-eye {
    left: 78px;
    top: 52px;
    transform: rotate(-5deg);
  }

  .mascot-pupil {
    position: absolute;
    left: 5px;
    top: 2px;
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #2b1408;
    box-shadow: 0 0 0 1.5px #050505;
    transition: transform 0.05s linear;
  }

  #mascot-lid {
    pointer-events: none;
    position: absolute;
    z-index: 10;
    inset-inline: 0;
    top: 0;
    height: 0;
    background: #050505;
    transition: height 0.1s ease-in;
  }
</style>

<script is:inline>
  (() => {
    const lines = [
      "Hi! Welcome to my little corner of the internet.",
      "Feel free to explore my research, publications, and projects.",
      "Warning: Mathematical curiosity may be contagious.",
      "Machine learning is easy... until the math shows up.",
      "Some ideas begin with coffee. The good ones end with proofs.",
      "Optimization is where mathematics meets intelligence.",
      "Behind every model is a mathematical story.",
      "Thanks for visiting - I hope you enjoy exploring my work!",
    ];

    const btn = document.getElementById("mascot-btn");
    const head = document.getElementById("mascot-head");
    const img = document.getElementById("mascot-img");
    const lid = document.getElementById("mascot-lid");
    const bubble = document.getElementById("mascot-bubble");
    const text = document.getElementById("mascot-text");
    const pupils = document.querySelectorAll(".mascot-pupil");

    let tx = 0, ty = 0;
    let cx = 0, cy = 0;

    window.addEventListener("mousemove", (e) => {
      const r = btn.getBoundingClientRect();
      const mx = r.left + r.width / 2;
      const my = r.top + r.height / 2;

      tx = Math.max(-1, Math.min(1, (e.clientX - mx) / 350));
      ty = Math.max(-1, Math.min(1, (e.clientY - my) / 350));
    });

    function animateFace() {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;

      const rotY = cx * 18;
      const rotX = -cy * 14;

      head.style.transform =
        `rotateY(${rotY}deg) rotateX(${rotX}deg) translate(${cx * 4}px, ${cy * 3}px)`;

      img.style.transform =
        `scale(1.5) translate(${cx * 4}px, ${cy * 3}px)`;

      pupils.forEach((p) => {
        p.style.transform = `translate(${cx * 4}px, ${cy * 3}px)`;
      });

      requestAnimationFrame(animateFace);
    }

    animateFace();

    function blink() {
      lid.style.height = "55%";
      setTimeout(() => { lid.style.height = "0"; }, 130);
      setTimeout(blink, 3000 + Math.random() * 4500);
    }

    setTimeout(blink, 2000);

    function showBubble(message, duration = 4000) {
      text.textContent = message;
      bubble.classList.remove("opacity-0", "translate-y-2");
      bubble.classList.add("opacity-100", "translate-y-0");

      setTimeout(() => {
        bubble.classList.add("opacity-0", "translate-y-2");
        bubble.classList.remove("opacity-100", "translate-y-0");
      }, duration);
    }

    setTimeout(() => showBubble(lines[0], 4500), 1200);

    let hideTimer = null;
    btn.addEventListener("click", () => {
      if (hideTimer) clearTimeout(hideTimer);
      showBubble(lines[Math.floor(Math.random() * lines.length)], 4000);
    });
  })();
</script>