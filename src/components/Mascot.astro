---
const lines = [
  "Hi! Welcome to my little corner of the internet. 👋",
  "Feel free to explore my research, publications, and projects.",
  "Warning: Mathematical curiosity may be contagious.",
  "Machine learning is easy... until the math shows up.",
  "Some ideas begin with coffee. The good ones end with proofs.",
  "Ask me about Lehmer Activation Units.",
  "Optimization is where mathematics meets intelligence.",
  "Behind every model is a mathematical story.",
  "Looking for a PhD student? We should probably talk.",
  "Thanks for visiting—I hope you enjoy exploring my work!"
];
---

<div id="mascot" class="fixed bottom-5 right-5 z-[60] select-none">
  <div
    id="mascot-bubble"
    class="pointer-events-none absolute bottom-full right-0 mb-4 w-72 rounded-2xl border border-white/10 bg-[#05070d]/95 px-5 py-4 text-sm italic leading-6 text-gray-200 opacity-0 shadow-2xl backdrop-blur-xl transition-all duration-300"
  >
    <span id="mascot-text">Hi! I'm Sepideh.</span>
    <span class="absolute -bottom-2 right-8 h-4 w-4 rotate-45 border-b border-r border-white/10 bg-[#05070d]"></span>
  </div>

  <button
    id="mascot-btn"
    aria-label="Talk to Sepideh avatar"
    class="group relative block h-32 w-32 overflow-hidden rounded-[2rem] border border-white/15 bg-[#05070d] shadow-2xl transition hover:scale-105 hover:border-blue-300/50 focus:outline-none"
  >
    <svg
      class="h-full w-full"
      viewBox="0 0 140 140"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <rect width="140" height="140" rx="28" fill="#05070d" />

      <!-- hair -->
      <path d="M35 122 C25 82, 30 42, 55 25 C73 13, 103 22, 113 52 C124 83, 115 108, 109 124"
        stroke="white" stroke-opacity="0.35" stroke-width="1.3" />
      <path d="M45 123 C36 82, 41 47, 62 29 C78 16, 101 29, 108 57 C115 87, 106 111, 101 124"
        stroke="white" stroke-opacity="0.55" stroke-width="1.2" />
      <path d="M52 25 C43 46, 39 78, 41 124"
        stroke="white" stroke-opacity="0.22" stroke-width="1" />
      <path d="M71 23 C83 51, 98 82, 94 124"
        stroke="white" stroke-opacity="0.22" stroke-width="1" />

      <!-- face -->
      <path d="M43 58 C45 36, 63 25, 82 30 C102 35, 110 54, 106 76 C102 101, 86 114, 68 111 C51 108, 41 84, 43 58Z"
        stroke="white" stroke-opacity="0.75" stroke-width="1.3" />

      <!-- eyebrows -->
      <path d="M54 58 C60 53, 66 53, 71 57" stroke="white" stroke-opacity="0.8" stroke-width="1.4" />
      <path d="M80 57 C86 52, 93 53, 98 58" stroke="white" stroke-opacity="0.8" stroke-width="1.4" />

      <!-- eyes -->
      <g class="eye" data-cx="62" data-cy="67">
        <path d="M52 67 C57 61, 67 61, 72 67 C67 73, 57 73, 52 67Z"
          stroke="white" stroke-opacity="0.9" stroke-width="1.2" />
        <circle class="pupil" cx="62" cy="67" r="3.2" fill="#7c3aed" />
        <circle class="highlight" cx="63.2" cy="65.8" r="0.9" fill="white" fill-opacity="0.9" />
        <rect class="lid" x="50" y="60" width="24" height="16" fill="#05070d" opacity="0" />
      </g>

      <g class="eye" data-cx="90" data-cy="67">
        <path d="M80 67 C85 61, 95 61, 100 67 C95 73, 85 73, 80 67Z"
          stroke="white" stroke-opacity="0.9" stroke-width="1.2" />
        <circle class="pupil" cx="90" cy="67" r="3.2" fill="#7c3aed" />
        <circle class="highlight" cx="91.2" cy="65.8" r="0.9" fill="white" fill-opacity="0.9" />
        <rect class="lid" x="78" y="60" width="24" height="16" fill="#05070d" opacity="0" />
      </g>

      <!-- nose -->
      <path d="M75 72 C72 79, 71 84, 77 85" stroke="white" stroke-opacity="0.55" stroke-width="1" />

      <!-- colored lips -->
      <path d="M62 94 C69 100, 82 100, 90 94" stroke="#f4a7b9" stroke-width="2.2" stroke-linecap="round" />
      <path d="M64 94 C70 91, 82 91, 88 94" stroke="#f4a7b9" stroke-opacity="0.8" stroke-width="1.3" />

      <!-- blazer -->
      <path d="M42 139 C50 119, 58 111, 69 111" stroke="white" stroke-opacity="0.35" stroke-width="1.2" />
      <path d="M107 139 C98 119, 87 111, 76 111" stroke="white" stroke-opacity="0.35" stroke-width="1.2" />

      <!-- earring -->
      <path d="M105 73 C110 81, 108 91, 104 96" stroke="white" stroke-opacity="0.45" stroke-width="1" />
    </svg>
  </button>
</div>

<style>
  .blink .lid {
    animation: blink 170ms ease-in-out;
  }

  @keyframes blink {
    0% {
      opacity: 0;
      transform: scaleY(0);
      transform-origin: center top;
    }
    45% {
      opacity: 1;
      transform: scaleY(1);
      transform-origin: center top;
    }
    100% {
      opacity: 0;
      transform: scaleY(0);
      transform-origin: center top;
    }
  }
</style>

<script is:inline>
  const lines = [
    "Still reading? Good. That means the design works.",
    "Ask me about Lehmer Activation Units.",
    "Currently optimizing this corner of the page.",
    "I promise this is not overfitting.",
    "Tiny avatar. Large research ambitions.",
    "PhD application mode: activated.",
  ];

  const btn = document.getElementById("mascot-btn");
  const bubble = document.getElementById("mascot-bubble");
  const text = document.getElementById("mascot-text");
  const eyes = document.querySelectorAll(".eye");

  let index = 0;

  function showBubble() {
    text.textContent = lines[index % lines.length];
    index++;

    bubble.classList.remove("opacity-0");
    bubble.classList.add("opacity-100");

    setTimeout(() => {
      bubble.classList.remove("opacity-100");
      bubble.classList.add("opacity-0");
    }, 4200);
  }

  btn?.addEventListener("click", showBubble);

  window.addEventListener("mousemove", (event) => {
    eyes.forEach((eye) => {
      const pupil = eye.querySelector(".pupil");
      const highlight = eye.querySelector(".highlight");

      const cx = Number(eye.dataset.cx);
      const cy = Number(eye.dataset.cy);

      const svg = eye.closest("svg");
      const rect = svg.getBoundingClientRect();

      const mouseX = ((event.clientX - rect.left) / rect.width) * 140;
      const mouseY = ((event.clientY - rect.top) / rect.height) * 140;

      const dx = mouseX - cx;
      const dy = mouseY - cy;
      const angle = Math.atan2(dy, dx);

      const radius = 2.6;
      const x = Math.cos(angle) * radius;
      const y = Math.sin(angle) * radius;

      pupil.setAttribute("transform", `translate(${x}, ${y})`);
      highlight.setAttribute("transform", `translate(${x}, ${y})`);
    });
  });

  function blink() {
    eyes.forEach((eye) => eye.classList.add("blink"));

    setTimeout(() => {
      eyes.forEach((eye) => eye.classList.remove("blink"));
    }, 190);

    const nextBlink = 2600 + Math.random() * 3600;
    setTimeout(blink, nextBlink);
  }

  setTimeout(blink, 1800);
</script>