---
import "../styles/global.css";
import Background from "../components/Background.astro";
import Mascot from "../components/Mascot.astro";

// ===== EDUCATION =====
const education = [
  {
    degree: "Master of Science in Data Science",
    school: "University of Colorado Boulder, USA",
    note: "GPA: 3.95 / 4.00",
  },
  {
    degree: "Graduate Certificate in Engineering Management (within the MSc program)",
    school: "University of Colorado Boulder, USA",
    note: "",
  },
  {
    degree: "Postgraduate Certificate in Applied AI Solutions Development",
    school: "George Brown College, Canada",
    note: "GPA: 3.90 / 4.00",
  },
];

// ===== PUBLICATIONS =====
const papers = [
  {
    venue: "Entropy 2026",
    year: "2026",
    title: "Compact and Interpretable Neural Networks Using Lehmer Activation Units",
    authors: "Masoud Ataei, Sepideh Forouzi, Xiaogang Wang",
    note: "Entropy, 28(2):157, 2026.",
    link: "https://doi.org/10.3390/e28020157",
  },
  {
    venue: "Under Review",
    year: "2025",
    title: "Mixed-Integer Nonlinear Programming Models for Exact and Interpretable Formulation of Neural Networks",
    authors: "Masoud Ataei, Sepideh Forouzi, Edrin Hasaj, Jacob Gipp",
    note: "Submitted to Neural Networks, 2025.",
    link: "https://arxiv.org/abs/2504.14356",
  },
  {
    venue: "Under Review",
    year: "2026",
    title: "Modeling Regime Structure and Informational Drivers of Stock Market Volatility via the Financial Chaos Index",
    authors: "Masoud Ataei, Sepideh Forouzi, Michael Chen, Zijiang Yang",
    note: "Submitted to Computational Economics, 2026.",
    link: "https://arxiv.org/abs/2504.18958",
  },
];

// ===== RESEARCH EXPERIENCE =====
const experience = [
  {
    role: "Machine Learning Scientist (Co-op)",
    org: "Kinectrics, Toronto, Canada",
    period: "Jan 2026 &ndash; Apr 2026",
    points: [
      "Developed and validated LSTM-based deep-learning models for anomaly detection on multivariate wind-farm time series, improving detection performance and reliability relative to baseline methods.",
      "Formulated and compared statistical, graph-based, and physics-informed approaches to anomaly detection; performed feature engineering, model validation, and threshold calibration on large-scale temporal data.",
      "Integrated trained models into an LLM-based decision-support tool for predictive maintenance, connecting classical machine-learning methods with large language model applications.",
      "Engineered reproducible data-processing pipelines (Python, SQL) supporting controlled experimentation, model evaluation, and performance monitoring over high-volume time series (10M+ records/day).",
    ],
  },
  {
    role: "Data Scientist",
    org: "Clínica Dra. Nahid & Dr. Masoud, Valencia, Spain",
    period: "Feb 2023 &ndash; Feb 2025",
    points: [
      "Developed predictive models (scikit-learn) for patient-outcome forecasting, applying feature engineering, statistical modeling, and cross-validation to structured and unstructured clinical data.",
      "Conducted exploratory and statistical analysis of healthcare datasets to identify clinically meaningful patterns and quantify predictive signal.",
      "Communicated analytical findings to clinical collaborators through reproducible visualizations (Power BI, Tableau).",
    ],
  },
];

// ===== GRADUATE COURSEWORK (from official transcript, CU Boulder) =====
const coursework = [
  {
    group: "Machine Learning & AI",
    color: "from-blue-400 to-cyan-400",
    items: ["Intro to Machine Learning: Supervised Learning", "Unsupervised Algorithms in ML", "Introduction to Deep Learning"],
  },
  {
    group: "Algorithms & Data Structures",
    color: "from-purple-400 to-fuchsia-400",
    items: ["Algorithms", "Trees and Graphs: Basics", "Programming and Algorithms"],
  },
  {
    group: "Statistics & Probability",
    color: "from-emerald-400 to-teal-400",
    items: ["Probability Theory", "Statistical Inference for Estimation", "Hypothesis Testing for Data Science", "Modern Regression Analysis in R", "Linear Models and Regression", "ANOVA and Experimental Design"],
  },
  {
    group: "Data Mining",
    color: "from-amber-400 to-orange-400",
    items: ["Data Mining Pipeline", "Data Mining Methods", "Data Mining Project"],
  },
  {
    group: "Data Systems & Databases",
    color: "from-sky-400 to-indigo-400",
    items: ["Relational Database Design", "Structured Query Language", "Data Science as a Field"],
  },
  {
    group: "Visualization & Ethics",
    color: "from-rose-400 to-pink-400",
    items: ["Fundamentals of Data Visualization", "Cybersecurity for Data Science", "Ethical Issues in Data Science"],
  },
  {
    group: "Engineering Management",
    color: "from-violet-400 to-purple-400",
    items: ["Production Cost, Investment & Cash-Flow Analysis", "Project Valuation & Capital Budgeting", "Financial Forecasting and Reporting", "Leading Oneself with Self-Knowledge", "Leading Oneself with Purpose & Meaning"],
  },
];

// ===== TECHNICAL SKILLS =====
const skills = [
  { group: "Programming", color: "from-blue-400 to-cyan-400", items: "Python, C/C++, SQL, R, MATLAB, Bash" },
  { group: "ML & Deep Learning", color: "from-purple-400 to-fuchsia-400", items: "PyTorch, TensorFlow, scikit-learn, XGBoost; CNNs, RNNs/LSTMs" },
  { group: "Optimization", color: "from-emerald-400 to-teal-400", items: "MILP, MINLP, convex optimization; Gurobi, CPLEX, Pyomo, AMPL" },
  { group: "Statistics & Time Series", color: "from-amber-400 to-orange-400", items: "Bayesian inference, MCMC, hypothesis testing, causal inference; ARIMA/SARIMAX" },
  { group: "Visualization", color: "from-rose-400 to-pink-400", items: "Power BI, Tableau" },
  { group: "Data, Cloud & Tools", color: "from-sky-400 to-indigo-400", items: "AWS (SageMaker, S3, EC2), Docker, Git, Linux, LaTeX, Jupyter" },
];

// ===== HONORS =====
const honors = [
  "Dean's Honour List, George Brown College (2025 &ndash; 2026).",
  "Sustained first-class graduate record: GPA 3.95/4.00 (CU Boulder) and 3.90/4.00 (George Brown College).",
];

// ===== CERTIFICATIONS =====
const certifications = [
  {
    title: "Google Advanced Data Analytics",
    issuer: "Coursera · Google",
    color: "from-blue-400 to-cyan-400",
    link: "https://www.coursera.org/account/accomplishments/professional-cert/GBW7CPG0FM7R",
  },
  {
    title: "Google Data Analytics",
    issuer: "Coursera · Google",
    color: "from-emerald-400 to-teal-400",
    link: "https://www.coursera.org/account/accomplishments/professional-cert/KCWC2Y4TPDQH",
  },
  {
    title: "Google Project Management",
    issuer: "Coursera · Google",
    color: "from-purple-400 to-fuchsia-400",
    link: "https://www.coursera.org/account/accomplishments/professional-cert/certificate/34E67NDWGIAY",
  },
  {
    title: "Cloud Computing Fundamentals",
    issuer: "IBM SkillsBuild · Credly",
    color: "from-amber-400 to-orange-400",
    link: "https://www.credly.com/badges/9ea3f02d-ed4b-4939-8828-d6e90b0d03f8/linked_in_profile",
  },
  {
    title: "Configure a Semantic Model",
    issuer: "Microsoft Learn",
    color: "from-sky-400 to-indigo-400",
    link: "https://learn.microsoft.com/en-us/users/sepidehforouzi-5395/achievements/pgq9l8f4",
  },
];

// ===== UPDATES =====
const updates = [
  { date: "Jan 2026", text: "Our paper on Lehmer Activation Units was published in Entropy (MDPI)!" },
  { date: "Jan 2026", text: "Joined Kinectrics as a Machine Learning Scientist (Co-op), working on deep-learning anomaly detection for wind-farm time series." },
  { date: "2025", text: "Two manuscripts on exact neural-network optimization and financial volatility submitted and released on arXiv." },
  { date: "2025", text: "Started my MSc in Data Science at the University of Colorado Boulder." },
];
---
<main class="relative min-h-screen bg-[#05070d] text-white">

  <Background />

  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/10 bg-[#05070d]/70 backdrop-blur-xl">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
      <a href="/" class="text-lg font-semibold tracking-wide">Sepideh Forouzi</a>
      <div class="hidden gap-6 text-sm text-gray-300 md:flex">
        <a href="#education" class="hover:text-white">Education</a>
        <a href="#publications" class="hover:text-white">Publications</a>
        <a href="#research" class="hover:text-white">Research</a>
        <a href="#coursework" class="hover:text-white">Coursework</a>
        <a href="#certifications" class="hover:text-white">Certifications</a>
        <a href="#skills" class="hover:text-white">Skills</a>
        <a href="#updates" class="hover:text-white">Updates</a>
      </div>
    </div>
  </nav>

  <!-- HERO: text pushed far down so it sits BELOW the 3D shape -->
  <section class="relative z-10 mx-auto grid max-w-7xl gap-12 px-6 pt-[34rem] pb-24 md:grid-cols-[0.9fr_1.1fr] md:items-start md:pt-[26rem]">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_20%_70%,rgba(59,130,246,0.18),transparent_30%),radial-gradient(circle_at_80%_80%,rgba(168,85,247,0.18),transparent_30%)]"></div>

    <div class="flex justify-center md:sticky md:top-32">
      <div class="relative">
        <div class="absolute -inset-4 rounded-full bg-blue-500/20 blur-2xl"></div>
        <img
          src="/images/profile.jpg"
          alt="Sepideh Forouzi"
          class="relative h-72 w-72 rounded-full border border-white/20 object-cover object-[center_10%] shadow-2xl md:h-96 md:w-96"
        />
      </div>
    </div>

    <div>
      <p class="mb-5 text-sm uppercase tracking-[0.35em] text-blue-300">
        Machine Learning &middot; Mathematical Optimization &middot; Interpretable AI &middot; Trustworthy AI
      </p>

      <h1 class="mb-6 text-5xl font-bold tracking-tight md:text-7xl">
        Sepideh Forouzi
      </h1>

      <div class="mb-8 max-w-2xl space-y-4 text-xl leading-8 text-gray-300">
        <p>Hi! I'm Sepideh.</p>

        <p>
          I am a machine learning researcher with a background in data science, artificial intelligence, and mathematical optimization. I hold an MSc in Data Science from the <a href="https://www.colorado.edu/" target="_blank" class="text-blue-300 underline-offset-4 hover:text-blue-100 hover:underline">University of Colorado Boulder</a> and a Postgraduate Certificate in Applied AI Solutions Development from <a href="https://www.georgebrown.ca/" target="_blank" class="text-blue-300 underline-offset-4 hover:text-blue-100 hover:underline">George Brown College</a>.
        </p>

        <p>
          My research lies at the intersection of <span class="text-gray-100">interpretable AI</span>, <span class="text-gray-100">neural network theory</span>, <span class="text-gray-100">optimization</span>, and <span class="text-gray-100">statistical machine learning</span>. I am particularly interested in developing mathematically grounded learning algorithms that are both theoretically rigorous and practically effective.
        </p>

        <p>
          Recently, I co-developed <a href="https://doi.org/10.3390/e28020157" target="_blank" class="text-blue-300 underline-offset-4 hover:text-blue-100 hover:underline">Lehmer Activation Units</a> (LAUs), a novel family of interpretable neural activation functions with universal approximation guarantees, published in <span class="italic">Entropy</span> (MDPI, 2026). I am also working on optimization-based formulations of neural networks using mixed-integer programming for interpretability, sparsity, and formal verification.
        </p>

        <p>
          Beyond my research, I enjoy building scalable AI systems spanning machine learning, large language models, time-series analysis, and optimization.
        </p>

        <p>
          I am currently seeking <span class="text-gray-100">PhD opportunities beginning in Fall 2027</span> and welcome opportunities for research collaboration.
        </p>
      </div>

      <div class="mt-8 flex items-center gap-6">

        <a href="https://scholar.google.com/citations?user=3812bFIAAAAJ&hl=en" target="_blank" class="transition hover:scale-110" title="Google Scholar">
          <svg class="h-8 w-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 24a7 7 0 1 1 0-14 7 7 0 0 1 0 14zm0-24L0 9.5l4.838 3.94A8 8 0 0 1 12 9a8 8 0 0 1 7.162 4.44L24 9.5z"/>
          </svg>
        </a>

        <a href="https://github.com/sepidfs" target="_blank" class="transition hover:scale-110" title="GitHub">
          <svg class="h-8 w-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.1 3.29 9.42 7.86 10.95.58.1.79-.25.79-.56v-2.18c-3.2.7-3.87-1.36-3.87-1.36-.53-1.34-1.3-1.7-1.3-1.7-1.06-.73.08-.72.08-.72 1.17.08 1.78 1.2 1.78 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.41-1.27.74-1.56-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.05 0 0 .98-.31 3.2 1.18A11.1 11.1 0 0 1 12 5.99c.99 0 1.99.13 2.92.39 2.22-1.49 3.2-1.18 3.2-1.18.63 1.59.23 2.76.11 3.05.75.81 1.2 1.84 1.2 3.1 0 4.42-2.69 5.39-5.25 5.68.42.36.79 1.08.79 2.18v3.23c0 .31.21.67.8.56A11.52 11.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/>
          </svg>
        </a>

        <a href="https://www.linkedin.com/in/sepideh-f-6b9163330/" target="_blank" class="transition hover:scale-110" title="LinkedIn">
          <svg class="h-8 w-8 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M4.98 3.5C4.98 4.88 3.86 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.5 8h4V24h-4V8Zm7.5 0h3.8v2.2h.05c.53-1 1.84-2.2 3.8-2.2 4.06 0 4.85 2.67 4.85 6.15V24h-4v-8.7c0-2.08-.04-4.75-2.9-4.75-2.9 0-3.35 2.27-3.35 4.6V24h-4V8Z"/>
          </svg>
        </a>

        <a href="mailto:sepideh.forouzi@colorado.edu" class="transition hover:scale-110" title="Email">
          <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M4 4h16v16H4z"/>
            <path d="m4 6 8 7 8-7"/>
          </svg>
        </a>

      </div>
    </div>

  </section>

  <section id="education" class="relative z-10 mx-auto max-w-7xl px-6 py-24">
    <h2 class="mb-10 text-4xl font-bold">Education</h2>
    <div class="space-y-6">
      {education.map((e) => (
        <div class="rounded-3xl border border-white/10 bg-white/5 p-7">
          <h3 class="text-2xl font-semibold">{e.degree}</h3>
          <p class="mt-1 text-blue-300">{e.school}</p>
          {e.note && <p class="mt-2 text-gray-400">{e.note}</p>}
        </div>
      ))}
    </div>
  </section>

  <section id="publications" class="relative z-10 mx-auto max-w-7xl px-6 py-24">
    <h2 class="mb-10 text-4xl font-bold">Selected Publications</h2>
    <div class="space-y-5">
      {papers.map((p) => (
        <div class="rounded-3xl border border-white/10 bg-white/5 p-7 transition hover:border-blue-400/40 hover:bg-white/[0.07]">
          <div class="mb-3 flex items-center gap-3">
            <span class="rounded-full bg-blue-500/15 px-3 py-1 text-xs font-medium text-blue-200">{p.venue}</span>
            <span class="text-xs text-gray-500">{p.year}</span>
          </div>
          <h3 class="text-2xl font-semibold leading-snug">
            <a href={p.link} target="_blank" class="bg-gradient-to-r from-blue-300 to-purple-300 bg-clip-text text-transparent transition hover:from-blue-200 hover:to-purple-200">
              {p.title}
            </a>
          </h3>
          <p class="mt-3 text-sm text-gray-400">{p.authors}</p>
          <p class="mt-1 text-sm italic text-gray-500">{p.note}</p>
          <a href={p.link} target="_blank" class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-blue-300 hover:text-blue-100">
            View Paper
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
              <path d="M15 3h6v6"/>
              <path d="M10 14 21 3"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </section>

  <section id="research" class="relative z-10 mx-auto max-w-7xl px-6 py-24">
    <h2 class="mb-10 text-4xl font-bold">Research Experience</h2>
    <div class="space-y-6">
      {experience.map((e) => (
        <div class="rounded-3xl border border-white/10 bg-white/5 p-7">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <h3 class="text-2xl font-semibold">{e.role}</h3>
            <span class="text-sm text-gray-500">{e.period}</span>
          </div>
          <p class="mt-1 text-blue-300">{e.org}</p>
          <ul class="mt-4 list-disc space-y-2 pl-5 text-gray-400">
            {e.points.map((pt) => (<li>{pt}</li>))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section id="coursework" class="relative z-10 mx-auto max-w-7xl px-6 py-24">
    <h2 class="mb-3 text-4xl font-bold">Graduate Coursework</h2>
    <p class="mb-4 text-gray-400">Selected graduate courses completed at CU Boulder (Data Science, MSc).</p>
    <div class="mb-10 flex flex-wrap gap-3 text-sm">
      <span class="rounded-full border border-blue-400/30 bg-blue-500/10 px-4 py-1.5 font-medium text-blue-200">33 graduate credits</span>
      <span class="rounded-full border border-emerald-400/30 bg-emerald-500/10 px-4 py-1.5 font-medium text-emerald-200">GPA 3.95 / 4.00</span>
      <span class="rounded-full border border-purple-400/30 bg-purple-500/10 px-4 py-1.5 font-medium text-purple-200">University of Colorado Boulder</span>
    </div>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {coursework.map((c) => (
        <div class="group overflow-hidden rounded-3xl border border-white/10 bg-white/5 transition hover:border-white/20 hover:bg-white/[0.07]">
          <div class={`h-1.5 w-full bg-gradient-to-r ${c.color}`}></div>
          <div class="p-6">
            <h3 class={`mb-4 bg-gradient-to-r ${c.color} bg-clip-text text-lg font-semibold text-transparent`}>{c.group}</h3>
            <div class="flex flex-wrap gap-2">
              {c.items.map((it) => (
                <span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm text-gray-300 transition group-hover:border-white/20">{it}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="certifications" class="relative z-10 mx-auto max-w-7xl px-6 py-24">
    <h2 class="mb-10 text-4xl font-bold">Certifications</h2>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {certifications.map((c) => (
        <a href={c.link} target="_blank" class="group block overflow-hidden rounded-3xl border border-white/10 bg-white/5 transition hover:border-white/20 hover:bg-white/[0.07]">
          <div class={`h-1.5 w-full bg-gradient-to-r ${c.color}`}></div>
          <div class="p-6">
            <h3 class={`bg-gradient-to-r ${c.color} bg-clip-text text-lg font-semibold text-transparent`}>{c.title}</h3>
            <p class="mt-2 text-sm text-gray-400">{c.issuer}</p>
            <span class="mt-4 inline-flex items-center gap-2 text-sm font-medium text-blue-300 group-hover:text-blue-100">
              View credential
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <path d="M15 3h6v6"/>
                <path d="M10 14 21 3"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>


  <section id="skills" class="relative z-10 mx-auto max-w-7xl px-6 py-24">
    <h2 class="mb-10 text-4xl font-bold">Technical Skills</h2>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {skills.map((s) => (
        <div class="group overflow-hidden rounded-3xl border border-white/10 bg-white/5 transition hover:border-white/20 hover:bg-white/[0.07]">
          <div class={`h-1.5 w-full bg-gradient-to-r ${s.color}`}></div>
          <div class="p-6">
            <h3 class={`mb-2 bg-gradient-to-r ${s.color} bg-clip-text text-lg font-semibold text-transparent`}>{s.group}</h3>
            <p class="text-gray-400">{s.items}</p>
          </div>
        </div>
      ))}
    </div>

    <h2 class="mb-6 mt-16 text-4xl font-bold">Honors & Awards</h2>
    <ul class="space-y-3">
      {honors.map((h) => (
        <li class="rounded-2xl border border-white/10 bg-white/5 p-5 text-gray-300">{h}</li>
      ))}
    </ul>

    <h2 class="mb-6 mt-16 text-4xl font-bold">Languages</h2>
    <p class="text-lg text-gray-300">English (proficient) &middot; German (proficient) &middot; Persian (native)</p>
  </section>

  <section id="updates" class="relative z-10 mx-auto max-w-7xl px-6 py-24">
    <h2 class="mb-12 text-center text-4xl font-bold">Latest Updates</h2>
    <div class="relative mx-auto max-w-3xl">
      <div class="absolute left-24 top-0 bottom-0 w-px bg-gradient-to-b from-blue-500 via-purple-500 to-transparent"></div>
      <div class="space-y-8">
        {updates.map((u) => (
          <div class="relative flex items-start gap-6">
            <div class="w-20 shrink-0 pt-4 text-right text-xs uppercase tracking-wider text-blue-300">{u.date}</div>
            <div class="relative mt-5 h-2 w-2 shrink-0 rounded-full bg-blue-400 ring-4 ring-blue-500/20"></div>
            <div class="flex-1 rounded-2xl border border-white/10 bg-white/5 p-5 text-gray-300">{u.text}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <footer class="relative z-10 border-t border-white/10 px-6 py-8 text-center text-sm text-gray-500">
    © 2026 Sepideh Forouzi. Built with Astro.
  </footer>

  <Mascot />
</main>
